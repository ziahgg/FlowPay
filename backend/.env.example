# Copy to .env and adjust for your environment. Never commit the real .env file.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=flowpay
DB_PASSWORD=flowpay
DB_NAME=flowpay

# Dev-only defaults below. Always override with real secrets outside local development.
JWT_SECRET=dev-only-insecure-secret-change-me-please-32chars
JWT_EXPIRES_IN=15m
SEED_ADMIN_PASSWORD=ChangeMe123!
DEPOSIT_MAX_AMOUNT=50000
TRANSFER_FEE_FLAT=0
IDEMPOTENCY_STALE_MS=30000
FX_SPREAD_BPS=50
RATE_CACHE_TTL_MS=30000

# Kafka (event-driven outbox + notifications). docker-compose overrides these to kafka:29092 for
# the containerized backend; localhost:9092 is correct when running the backend natively.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=flowpay-backend
NOTIFICATIONS_CONSUMER_GROUP_ID=flowpay-notifications

# SMTP (dev: Mailhog, see docker-compose.yml -- nothing is ever really emailed)
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=no-reply@flowpay.dev
