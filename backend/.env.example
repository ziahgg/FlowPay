# Copy to .env and adjust for your environment. Never commit the real .env file.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=flowpay
DB_PASSWORD=flowpay
DB_NAME=flowpay

# Dev-only defaults below. Always override with real secrets outside local development.
JWT_SECRET=dev-only-insecure-secret-change-me-please-32chars
JWT_EXPIRES_IN=15m
SEED_ADMIN_PASSWORD=ChangeMe123!
DEPOSIT_MAX_AMOUNT=50000
TRANSFER_FEE_FLAT=0
IDEMPOTENCY_STALE_MS=30000
